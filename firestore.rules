// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: userId
// Fields:
//   - id: string (required)
//   - name: string (required)
//   - whatsapp: string (required)
//   - avatar: string (optional)
//   - skinType: string (optional)
//   - concerns: list (optional)
//   - points: number (optional)
//   - level: number (optional)
//   - badges: list (optional)
//   - completedChallenges: list (optional)
//   - history: list (optional)
//   - analysisHistory: list (optional)
//   - voiceSettings: map (optional)
//   - onboardingSeen: list (optional)
//
// Collection: staff
// Document ID: staffId
// Fields:
//   - id: string (required)
//   - name: string (required)
//   - role: string (required)
//   - whatsapp: string (required)
//   - created_at: number (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "athlavix@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['id', 'name', 'whatsapp']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.whatsapp is string && data.whatsapp.size() > 5 && data.whatsapp.size() < 20;
    }

    function isValidStaff(data) {
      return hasRequiredFields(['id', 'name', 'role', 'whatsapp', 'created_at']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role is string && data.role.size() > 0 && data.role.size() < 100 &&
             data.whatsapp is string && data.whatsapp.size() > 5 && data.whatsapp.size() < 20 &&
             data.created_at is int;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read and write their own data
      // Admins can read and write all user data
      allow read: if isOwner(userId) || isAdmin();
      allow create: if (isOwner(userId) && isValidUser(request.resource.data)) || isAdmin();
      allow update: if (isOwner(userId) && isValidUser(request.resource.data)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /staff/{staffId} {
      // Only admins can manage staff
      allow read: if isAdmin();
      allow write: if isAdmin() && (request.method == 'delete' || isValidStaff(request.resource.data));
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
